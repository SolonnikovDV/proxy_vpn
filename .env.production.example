# Production template.
CADDYFILE_PATH=Caddyfile.prod
VPN_PANEL_DOMAIN=panel.example.com

# Public host ports
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Xray on same host should use another port unless you implement L4 multiplexing.
XRAY_PORT=8443
WG_PORT=51820
# Stable client-facing ports (can differ from runtime ports; server applies dynamic port map).
XRAY_CLIENT_PORT=8443
WG_CLIENT_PORT=51820

# Capacity guardrails
CAPACITY_TARGET_ACTIVE_USERS=15
CAPACITY_CPU_WARN_P95=70
CAPACITY_CPU_CRIT_P95=80
CAPACITY_RAM_WARN_P95=80
CAPACITY_RAM_CRIT_P95=85
CAPACITY_DISK_WARN_P95=85
CAPACITY_DISK_CRIT_P95=92
DASHBOARD_REFRESH_SECONDS=30

# App-side login rate-limit (panel/API auth endpoints)
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=10
LOGIN_LOCK_MINUTES=15

# Security guard container (attack telemetry + auto-blocklist)
SECURITY_GEOIP_ENABLED=1
SECURITY_GEOIP_TIMEOUT_SECONDS=1.5
SECURITY_DEFAULT_BLOCK_SECONDS=900
SECURITY_HTTP_WINDOW_SECONDS=10
SECURITY_HTTP_MAX_REQUESTS=120
SECURITY_PROBE_PATH_THRESHOLD=12
SECURITY_BLOCK_SECONDS_DDOS=600
SECURITY_BLOCK_SECONDS_BRUTE=900
SECURITY_SERVER_CHECK_INTERVAL_SECONDS=60
SECURITY_SERVER_EVENT_COOLDOWN_SECONDS=300

# Application identity and secret file paths.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
APP_SECRET_KEY_FILE=/etc/proxy-vpn/secrets/app_secret_key
ADMIN_PASSWORD_FILE=/etc/proxy-vpn/secrets/admin_password

# Dynamic resource-list sync (whitelist/blacklist) from remote feeds.
# Comma/newline separated URLs. Supports plain text/CSV/JSON payloads.
PROXY_BYPASS_FEED_URLS=
RKN_BLACKLIST_FEED_URLS=
PROXY_BYPASS_SYNC_ENABLED=1
RKN_BLACKLIST_SYNC_ENABLED=1
PROXY_BYPASS_SYNC_MODE=merge
RKN_BLACKLIST_SYNC_MODE=merge
PROXY_BYPASS_PRESERVE_FORCE_VPN_ON_REPLACE=1
LIST_SYNC_HTTP_TIMEOUT_SECONDS=20
LIST_SYNC_MAX_ITEMS=15000
LIST_SYNC_STRICT=0

# ----------------------------------------------------------------------
# GitHub CI/CD mapping (commented reference only; do not commit real values)
# Use script: scripts/setup-github-config.sh
#
# Variables:
#   SSH_HOST=<server-host-or-ip>
#   SSH_USER=<deploy-user>
#   DEPLOY_PATH=/opt/proxy_vpn
#   VPN_PANEL_DOMAIN=<public-domain>
#   ADMIN_USERNAME=admin
#   ADMIN_EMAIL=admin@example.com
#   APP_SECRET_KEY_FILE=/etc/proxy-vpn/secrets/app_secret_key
#   ADMIN_PASSWORD_FILE=/etc/proxy-vpn/secrets/admin_password
#
# Optional secret (only for GitHub -> SSH deploy):
#   DEPLOY_SSH_KEY=<private-key-content>
# ----------------------------------------------------------------------
