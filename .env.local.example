# Local development template.
# Copy to .env for local/dev.
# Project name is compose.yaml top-level `name: proxy-vpn`.

# Caddy config inside ./caddy (dev/prod switch)
CADDYFILE_PATH=Caddyfile.dev

# Production domain for Caddyfile.prod (ignored in dev)
VPN_PANEL_DOMAIN=panel.example.com

# WireGuard UDP (host)
WG_PORT=51820

# Caddy host ports for local/dev (avoid conflicts with host 80/443)
CADDY_HTTP_PORT=18080
CADDY_HTTPS_PORT=18443

# Xray TCP on host (local/dev default)
XRAY_PORT=14443

# Capacity guardrails (admin overview + scripts/capacity-check.sh)
CAPACITY_TARGET_ACTIVE_USERS=15
CAPACITY_CPU_WARN_P95=70
CAPACITY_CPU_CRIT_P95=80
CAPACITY_RAM_WARN_P95=80
CAPACITY_RAM_CRIT_P95=85
CAPACITY_DISK_WARN_P95=85
CAPACITY_DISK_CRIT_P95=92
DASHBOARD_REFRESH_SECONDS=30

# App-side login rate-limit (panel/API auth endpoints)
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=10
LOGIN_LOCK_MINUTES=15

# Security guard container (attack telemetry + auto-blocklist)
SECURITY_GEOIP_ENABLED=1
SECURITY_GEOIP_TIMEOUT_SECONDS=1.5
SECURITY_DEFAULT_BLOCK_SECONDS=900
SECURITY_HTTP_WINDOW_SECONDS=10
SECURITY_HTTP_MAX_REQUESTS=120
SECURITY_PROBE_PATH_THRESHOLD=12
SECURITY_BLOCK_SECONDS_DDOS=600
SECURITY_BLOCK_SECONDS_BRUTE=900
SECURITY_SERVER_CHECK_INTERVAL_SECONDS=60
SECURITY_SERVER_EVENT_COOLDOWN_SECONDS=300

# App auth defaults for local tests only.
APP_SECRET_KEY=dev-local-secret-key
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin123!
