# Copy to volume as wg0.conf and replace keys. Generate: wg genkey | tee priv | wg pubkey
# Server must use the same volume path /etc/wireguard/wg0.conf in container.

[Interface]
Address = 10.13.0.1/24
ListenPort = 51820
PrivateKey = YOUR_SERVER_PRIVATE_KEY

# PostUp/PostDown for NAT — adjust eth0 to outbound interface inside container (often eth0)
PostUp = iptables -t nat -A POSTROUTING -o eth0 -j MASQUERADE
PostDown = iptables -t nat -D POSTROUTING -o eth0 -j MASQUERADE

# [Peer] blocks added by control plane per user device
# [Peer]
# PublicKey = ...
# AllowedIPs = 10.13.0.2/32
