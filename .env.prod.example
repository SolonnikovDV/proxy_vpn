# Production template.
CADDYFILE_PATH=Caddyfile.prod
VPN_PANEL_DOMAIN=panel.example.com

# Public host ports
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Xray on same host should use another port unless you implement L4 multiplexing.
XRAY_PORT=8443
WG_PORT=51820

# Application security settings (MUST be changed in production).
APP_SECRET_KEY=replace-with-long-random-secret
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-admin-password
