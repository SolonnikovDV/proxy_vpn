{
    admin off
}

:80 {
    encode gzip
    reverse_proxy /health api:8000
    reverse_proxy /api/* api:8000
    reverse_proxy /docs api:8000
    reverse_proxy /openapi.json api:8000
    respond "proxy-vpn: use /api/v1/meta or /docs" 200
}

# HTTPS for panel on host port 8443 (host maps 8443 -> container 443).
# Xray uses host port 443 separately — see compose.yaml.
:443 {
    encode gzip
    tls internal
    reverse_proxy /health api:8000
    reverse_proxy /api/* api:8000
    reverse_proxy /docs api:8000
    reverse_proxy /openapi.json api:8000
    respond "proxy-vpn HTTPS — trust internal CA or replace with public domain" 200
}
