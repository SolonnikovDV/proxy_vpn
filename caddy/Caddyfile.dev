{
    admin off
}

:80 {
    encode gzip
    handle / {
        reverse_proxy api:8000
    }
    handle /admin {
        reverse_proxy api:8000
    }
    handle /cabinet {
        reverse_proxy api:8000
    }
    handle /login {
        reverse_proxy api:8000
    }
    handle /health {
        reverse_proxy api:8000
    }
    handle /api/* {
        reverse_proxy api:8000
    }
    handle /docs {
        reverse_proxy api:8000
    }
    handle /openapi.json {
        reverse_proxy api:8000
    }
    handle {
        respond "proxy-vpn: use /api/v1/meta or /docs" 200
    }
}

localhost:443 {
    encode gzip
    tls internal
    handle / {
        reverse_proxy api:8000
    }
    handle /admin {
        reverse_proxy api:8000
    }
    handle /cabinet {
        reverse_proxy api:8000
    }
    handle /login {
        reverse_proxy api:8000
    }
    handle /health {
        reverse_proxy api:8000
    }
    handle /api/* {
        reverse_proxy api:8000
    }
    handle /docs {
        reverse_proxy api:8000
    }
    handle /openapi.json {
        reverse_proxy api:8000
    }
    handle {
        respond "proxy-vpn HTTPS (dev/self-signed)" 200
    }
}
